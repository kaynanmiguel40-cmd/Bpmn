# Variaveis pro docker-compose.evolution.yml
# Copie para .env.evolution (NUNCA comitar) e ajuste antes de subir os containers.

# URL publica da Evolution API (com HTTPS via reverse proxy)
EVOLUTION_SERVER_URL=https://evo.seudominio.com

# Chave de autenticacao da Evolution API (gere uma string forte aleatoria, >= 32 chars)
# Sugestao: openssl rand -hex 32
EVOLUTION_API_KEY=GERAR_CHAVE_ALEATORIA_FORTE_AQUI

# URL do webhook do Supabase pra onde a Evolution vai postar eventos
# Substitua SEU_PROJETO pelo project ref do Supabase
EVOLUTION_WEBHOOK_URL=https://SEU_PROJETO.supabase.co/functions/v1/evolution-webhook

# Postgres da Evolution (separado do Supabase, so pra estado interno do gateway)
POSTGRES_USER=evolution
POSTGRES_PASSWORD=ALTERE_PARA_SENHA_FORTE
POSTGRES_DB=evolution
