VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_CASA_DOS_DADOS_API_KEY=your-casa-dos-dados-api-key

# Instagram Publishing - Modo Empresa (conta única)
# Gere o token no Meta Graph API Explorer: https://developers.facebook.com/tools/explorer/
# 1. Selecione seu app
# 2. Selecione "Get User Access Token"
# 3. Marque: instagram_business_basic, instagram_business_content_publish
# 4. Clique "Generate Access Token"
# 5. Converta para Long-Lived Token (60 dias) usando a Edge Function ou Graph API
VITE_META_APP_ID=your-meta-app-id
VITE_META_ACCESS_TOKEN=your-long-lived-instagram-token
VITE_META_INSTAGRAM_USER_ID=your-instagram-user-id

# Google Calendar Integration (Client-Side GIS OAuth)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Google Calendar Edge Function env vars (configurar no Supabase Dashboard)
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-project.supabase.co/functions/v1/gcal-oauth-callback
# APP_URL=https://your-app-domain.com

# Deploy SSH — usados apenas por deploy.mjs (nao expostos ao bundle do navegador).
# Recomendado migrar pra autenticacao por chave SSH em vez de senha.
DEPLOY_SSH_HOST=your-server-ip
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=root
DEPLOY_SSH_PASSWORD=your-ssh-password
